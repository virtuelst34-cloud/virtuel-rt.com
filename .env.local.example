# Variables d'environnement pour Virtuel-RT
# Copiez ce fichier en .env.local et remplissez les valeurs

# Supabase (requis)
VITE_SUPABASE_URL=votre_url_supabase
VITE_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# Sentry (optionnel - pour le monitoring d'erreurs en production)
# VITE_SENTRY_DSN=votre_dsn_sentry
